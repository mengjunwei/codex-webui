# Required: access key for WebUI API/WebSocket authentication
WEBUI_API_KEY=change-me-to-a-random-secret

# Optional: backend listen port (default 8172)
PORT=8172

# Optional: OpenAI API key (required for Codex to work)
OPENAI_API_KEY=

# Optional: Pino log level (default: info)
# LOG_LEVEL=info

# Optional: path to codex CLI binary (default: codex)
# CODEX_BIN=codex

# Optional: codex home directory (default: ~/.codex)
# CODEX_HOME=/codex-home

# Optional: SQLite database path (default: CODEX_HOME/codex-webui.sqlite)
# WEBUI_DB_PATH=

# Optional: OTLP collector endpoint for distributed tracing export.
# When set (non-empty), tracing spans are exported via gRPC to an
# OpenTelemetry-compatible backend (Jaeger / Tempo / Grafana / Datadog /
# OTel Collector). When unset, the OTLP layer is not installed (zero overhead).
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# Runtime settings such as workspace roots, upload limits, and terminal
# defaults/limits are stored in SQLite and can be changed from Settings.
# Their legacy env vars still work as fallback overrides when no DB value is set.

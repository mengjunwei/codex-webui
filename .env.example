# ─────────────────────────────────────────────────────────────
# 多副本 HA Codex 平台 —— 环境变量(.env 模板)
# 架构:全局 CODEX_HOME(所有 team 共用)+ per-team codex 进程 + session 级 rollout
#       增量复制到副本 + 探活 + 副本晋升。所有节点同配置。
# ─────────────────────────────────────────────────────────────

# [必填] WebUI API/WebSocket 访问密钥(≥16 字符,随机长串)
WEBUI_API_KEY=change-me-to-a-random-secret-of-at-least-16-chars

# [必填] 多方言数据库连接串(postgresql:// 或 mysql://)
DATABASE_URL=postgres://codex:codex@postgres:5432/codex

# [可选] Redis(事件总线/限流/复制 offset/集群心跳)。不配 = 单节点(无副本/无 failover)。
REDIS_URL=redis://redis:6379

# ── 多副本 HA ──
# 全局 CODEX_HOME(所有 team 共用;team 仅前端 UI 隔离,不隔离目录/进程)。
# CODEX_HOME=/root/.codex-webui/home
# 节点 id(多机建议显式设置,保证跨重启一致;否则每次启动随机 UUID → 触发 failover)。
# WORKER_ID=node-1
# 集群探活后端:redis(默认,心跳 TTL)| memberlist(需编译时 enable feature `memberlist-backend`)。
# CLUSTER_BACKEND=redis
# 本节点对内可达的 RPC 地址(多机必填,供其他节点转发请求/复制 rollout)。
# WORKER_RPC_URL=http://10.0.0.5:8173
# WORKER_RPC_TOKEN=shared-internal-secret   # 内网 RPC 鉴权(多机强烈建议设置)
# INTERNAL_RPC_PORT=8173                    # 默认 PORT+1

# ── 进程池调度(均有默认值)──
# MAX_PROCESSES_PER_TEAM=4                # 每 team codex 进程上限
# MAX_GLOBAL_PROCESSES=25                 # 全局进程上限(达上限 LRU 回收)
# IDLE_EVICT_SECS=900                     # 空闲回收(15min)
# MAX_CONCURRENT_PER_PROCESS=20           # 单进程并发上限(semaphore)
# PROCESS_SCALE_THRESHOLD=8              # 并发达阈值触发按 team 扩进程

# ── 加密 / 密钥轮转(M6)──
# MASTER_KEY=                             # 加密 team API key(AES-256-GCM);未设则回退 WEBUI_API_KEY
# MASTER_KEY_PREVIOUS=                    # 轮转过渡:旧 master,当前 master 解密失败时回退

# ── 计费/配额(M6 预留)──
# DEFAULT_TURN_QUOTA_HOURLY=0             # 新 team 默认每小时 turn 配额(0=不限)

# ── 监听 ──
PORT=8172
# HOST=0.0.0.0

# ── 旧单用户兼容(BYOK 启用前的全局 codex 进程)──
OPENAI_API_KEY=
# CODEX_BIN=codex

# ── 日志 / 分布式追踪 ──
# LOG_LEVEL=info
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# ── docker-compose 专用 ──
POSTGRES_PASSWORD=codex
